generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    @default("USER")  // "ADMIN" ou "USER"
  createdAt     DateTime  @default(now())
}

model Client {
  id              String        @id @default(uuid())
  tenantId        String        // Multi-tenancy: isolamento por application logic

  name            String
  status          String        @default("TRIAGEM")
  lastAction      String
  case            String
  area            String

  // --- LAW SOVEREIGN v3.5: ARMAS DE ESCALA ---
  chanceOfSuccess Int?
  costOfWaiting   Float?
  missingProofs   String?
  isPaperLead     Boolean         @default(false)
  isEncaminhado   Boolean         @default(false)
  phone           String?

  createdAt       DateTime        @default(now())
  deletedAt       DateTime?       // Soft delete: null = ativo, non-null = deletado

  @@index([tenantId])
  @@index([deletedAt])
}

model TimelineEvent {
  id         String   @id @default(uuid())
  tenantId   String   // Multi-tenancy: isolamento por application logic
  clientId   String
  date       String
  type       String
  content    String
  attachment Json?

  @@index([tenantId])
  @@index([clientId])
}

model AuditLog {
  id             String   @id @default(uuid())
  tenantId       String   // Multi-tenancy: isolamento por application logic
  email          String   // Email do usuário que realizou a ação
  action         String   // CREATE, READ, UPDATE, DELETE, LOGIN, NUKE
  resourceType   String   // Client, TimelineEvent, Tenant, etc
  resourceId     String   // ID do recurso afetado
  success        Boolean  @default(true)
  error          String?  // Mensagem de erro se falhou
  metadata       Json?    // Dados adicionais (e.g. valores antigos/novos para UPDATE)
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([email])
}
