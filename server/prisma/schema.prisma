generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String          @id @default(uuid())
  name            String
  status          String
  isEncaminhado   Boolean         @default(false)
  lastAction      String
  case            String
  area            String
  
  // --- LAW SOVEREIGN v3.5: ARMAS DE ESCALA ---
  chanceOfSuccess Int?            
  costOfWaiting   Float?          
  missingProofs   String?         
  isPaperLead     Boolean         @default(false)
  phone           String?

  createdAt       DateTime        @default(now())
  events          TimelineEvent[]
}

model TimelineEvent {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date       String
  type       String
  content    String
  attachment Json?    
}
