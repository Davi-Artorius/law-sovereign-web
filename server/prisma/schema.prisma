generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    @default("USER")  // "ADMIN" ou "USER"
  createdAt     DateTime  @default(now())

  clients       Client[]
  events        TimelineEvent[]
}

model Client {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  status          String        @default("TRIAGEM")
  lastAction      String
  case            String
  area            String

  // --- LAW SOVEREIGN v3.5: ARMAS DE ESCALA ---
  chanceOfSuccess Int?
  costOfWaiting   Float?
  missingProofs   String?
  isPaperLead     Boolean         @default(false)
  isEncaminhado   Boolean         @default(false)
  phone           String?

  createdAt       DateTime        @default(now())
  events          TimelineEvent[]

  @@index([tenantId])
}

model TimelineEvent {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date       String
  type       String
  content    String
  attachment Json?

  @@index([tenantId])
  @@index([clientId])
}
