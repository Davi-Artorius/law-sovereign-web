# ─── BANCO DE DADOS ─────────────────────────────────────────────────────────
# PostgreSQL — Railway gera isso automaticamente como DATABASE_URL
DATABASE_URL=postgresql://admin:sovereign_pass@localhost:5432/law_sovereign

# ─── SERVIDOR ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── SEGURANÇA ───────────────────────────────────────────────────────────────
# URL exata do frontend no Vercel (sem barra no final)
# Ex: https://law-sovereign.vercel.app
ALLOWED_ORIGIN=https://SEU-APP.vercel.app

# Chave secreta compartilhada entre Railway (backend) e Vercel (frontend).
# Gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=GERE_UMA_CHAVE_AQUI

# ─── OCR (OPCIONAL) ──────────────────────────────────────────────────────────
GEMINI_API_KEY=SUA_CHAVE_GEMINI
OCR_MODEL=gemini-2.5-flash
